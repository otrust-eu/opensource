# OTRUST self-host configuration
# Copy to .env and change production values before exposing the server.

NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=otrust

# Security
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-in-production
ADMIN_KEY=
CORS_ORIGINS=http://localhost:3000

# OpenTimestamps / Bitcoin anchoring
# Keep disabled for local development unless opentimestamps-client is installed.
ENABLE_BLOCKCHAIN=false
# OTRUST_MOCK_OTS=true
# OTS_CLI_COMMAND=ots
# OTS_CLI_TIMEOUT_MS=120000

# Email
ENABLE_EMAIL=false
EMAIL_MODE=mock
EMAIL_FROM=OTRUST <noreply@example.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# RESEND_API_KEY=

# OTRUST Signed email webhook
# EMAIL_SIGN_WEBHOOK_SECRET=
# ADMIN_EMAIL=admin@example.com

# Optional processors
OTS_BATCH_INTERVAL_MS=300000
FILE_PURGE_INTERVAL_MS=60000
