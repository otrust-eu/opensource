# OTRUST Environment Configuration
# Copy this to .env and fill in your values

# MongoDB connection
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=otrust

# Server port
PORT=3000

# Node environment
NODE_ENV=development

# OpenTimestamps CLI for real Bitcoin anchoring.
# Install opentimestamps-client so `ots` is available, or set an explicit path.
# OTS_CLI_COMMAND=ots
# OTS_CLI_TIMEOUT_MS=120000

# ============================================
# EMAIL CONFIGURATION (choose one method)
# ============================================

# Option 1: Resend API (recommended for production)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Option 2: SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# ============================================
# OTRUST SIGN - Email Signing Feature
# ============================================

# Secret for email webhook authentication (generate with: openssl rand -hex 32)
# EMAIL_SIGN_WEBHOOK_SECRET=

# Admin API key for blocking abusive senders (generate with: openssl rand -hex 32)
# ADMIN_KEY=

# Email to receive abuse reports
# ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# SECURITY NOTES
# ============================================
# - Never commit .env files to git
# - Use strong random secrets (min 32 chars)
# - The app never logs IP addresses - privacy by design
# - All secrets should be set via environment variables
