{
  "name": "@otrust/opensource",
  "version": "1.0.0",
  "private": true,
  "description": "Open source SDKs, CLI tools, cryptographic helpers, and examples for OTRUST.",
  "type": "module",
  "license": "MIT",
  "author": "Kris Ledel <kris@otrust.eu>",
  "repository": {
    "type": "git",
    "url": "https://github.com/otrust-eu/opensource.git"
  },
  "homepage": "https://otrust.eu",
  "bugs": {
    "url": "https://github.com/otrust-eu/opensource/issues"
  },
  "workspaces": [
    "sdk-js",
    "sdk-react",
    "circuits"
  ],
  "bin": {
    "otrust": "./cli/otrust.js"
  },
  "scripts": {
    "build": "npm run build --workspace @otrust/sdk && npm run build --workspace @otrust/react",
    "test": "npm run test:core && npm run test --workspace @otrust/sdk && npm run test --workspace @otrust/react",
    "test:core": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand test/crypto.test.js test/pow.test.js test/validation.test.js",
    "typecheck": "npm run typecheck --workspace @otrust/sdk && npm run typecheck --workspace @otrust/react",
    "circuits:test": "npm --prefix circuits test"
  },
  "keywords": [
    "otrust",
    "timestamp",
    "opentimestamps",
    "bitcoin",
    "cryptography",
    "digital-signatures",
    "identity",
    "proofs",
    "sdk",
    "zero-knowledge"
  ],
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.3.3",
    "@noble/secp256k1": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
