{
  "name": "@otrust/react",
  "version": "1.0.0",
  "description": "React components for OTRUST - Login, Proof badges, Timestamp widgets",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@otrust/sdk": "file:../sdk-js"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "vite": "^8.0.16",
    "ws": "^8.21.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1",
      "picomatch": "^4.0.4",
      "postcss": "^8.5.10",
      "rollup": "^4.60.4",
      "vite": "^8.0.16",
      "ws": "^8.21.0"
    }
  },
  "keywords": [
    "otrust",
    "react",
    "authentication",
    "login",
    "identity",
    "timestamp",
    "proof",
    "zero-knowledge"
  ],
  "author": "OTRUST",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/otrust/sdk-react"
  },
  "homepage": "https://otrust.eu/docs/react"
}
