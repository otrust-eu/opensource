{
  "name": "otrust-circuits",
  "version": "1.0.0",
  "type": "module",
  "description": "OTRUST ZK Proof Circuits",
  "scripts": {
    "compile:age": "circom ageProof.circom -l .. --r1cs --wasm --sym -o build",
    "compile:income": "circom incomeProof.circom -l .. --r1cs --wasm --sym -o build",
    "compile:membership": "circom membershipProof.circom -l .. --r1cs --wasm --sym -o build",
    "compile:all": "node scripts/prepare-build.js && npm run compile:age && npm run compile:income && npm run compile:membership",
    "setup:age": "node scripts/trusted-setup.js ageProof",
    "setup:income": "node scripts/trusted-setup.js incomeProof",
    "setup:membership": "node scripts/trusted-setup.js membershipProof",
    "setup": "npm run setup:age && npm run setup:income && npm run setup:membership",
    "build": "npm run compile:all && npm run setup",
    "test": "node test.js",
    "verify:published": "node scripts/verify-published.js",
    "verify:production": "node scripts/verify-published.js --require-production"
  },
  "dependencies": {
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.4"
  },
  "overrides": {
    "bfj": "^9.1.3",
    "ws": "^8.21.0"
  }
}
