{
  "name": "otrust-circuits",
  "version": "1.0.0",
  "type": "module",
  "description": "OTRUST ZK Proof Circuits",
  "scripts": {
    "setup": "node scripts/setup.js",
    "compile:age": "circom ageProof.circom --r1cs --wasm --sym -o build",
    "compile:income": "circom incomeProof.circom --r1cs --wasm --sym -o build",
    "compile:membership": "circom membershipProof.circom --r1cs --wasm --sym -o build",
    "compile:all": "npm run compile:age && npm run compile:income && npm run compile:membership",
    "setup:age": "node scripts/trusted-setup.js ageProof",
    "setup:income": "node scripts/trusted-setup.js incomeProof",
    "setup:membership": "node scripts/trusted-setup.js membershipProof",
    "build": "npm run compile:all && npm run setup:age && npm run setup:income",
    "test": "node scripts/test-proof.js"
  },
  "dependencies": {
    "circomlib": "^2.0.5",
    "snarkjs": "^0.7.4"
  },
  "overrides": {
    "bfj": "^9.1.3"
  }
}
